# Base networks
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Etherscan API V2 key for source-code verification across supported chains.
ETHERSCAN_API_KEY=your_etherscan_v2_api_key

# Deployer private key. Use a dedicated deployment wallet and never commit .env.
DEPLOYER_PRIVATE_KEY=0xyour_testnet_private_key

# ABI-compatible fee wallet. Current source uses absolute 0% protocol fee, so no normal fee accrues.
FEE_WALLET=0xyour_fee_wallet_address

# Optional. Default is 0x000000000000000000000000000000000000dEaD.
DEAD_WALLET=0x000000000000000000000000000000000000dEaD

# SDK examples
AI_ESCROW_RPC_URL=https://mainnet.base.org
AI_ESCROW_CONTRACT_ADDRESS=0xc2a7524864d1998454EB6CF09242B9D33257F6Bf
AI_BUYER_PRIVATE_KEY=0xbuyer_agent_private_key
AI_SELLER_ADDRESS=0xseller_agent_wallet
AI_ESCROW_CHAIN_ID=8453
AI_ESCROW_AMOUNT_ETH=0.001
AI_ESCROW_AMOUNT_WEI=1000000000000000
AI_ESCROW_DURATION_SECONDS=3600
